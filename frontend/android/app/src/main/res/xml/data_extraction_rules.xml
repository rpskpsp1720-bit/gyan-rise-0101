<?xml version="1.0" encoding="utf-8"?>
<!--
  Data extraction rules (Android 12+).
  Prevents auto-backup and device-transfer of any app data —
  including web cookies, JWT tokens cached by the WebView,
  and any local storage written by the React app.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
