# Production environment template for Render backend deployment.
# Copy each key to Render → Service → Environment → Environment Variables.
# NEVER commit the actual .env file (it is gitignored).

# --- Database (MongoDB Atlas) ---
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
DB_NAME=gyan_rise_lms

# --- Auth ---
JWT_SECRET=<64-char-random-hex-string>

# --- Frontend / CORS (production) ---
# FRONTEND_URL is the canonical customer-facing origin used in emails / redirects.
FRONTEND_URL=https://gyanrise.in
# CORS_ORIGINS is a comma-separated allow-list. Entries with '*' become regex.
CORS_ORIGINS=https://gyanrise.in,https://www.gyanrise.in,https://gyan-rise-0101.vercel.app,https://*.vercel.app

# --- Seed accounts (used only on first startup for empty DB) ---
ADMIN_EMAIL=admin@lms.com
ADMIN_PASSWORD=<strong-admin-password>
STUDENT_EMAIL=<student-email>
STUDENT_PASSWORD=<student-password>

# --- Razorpay (fill on Render dashboard, never commit real keys) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Optional flags ---
# Set to 'true' ONLY to reseed sample content (destroys existing seeded batches).
SEED_CONTENT=false
